# BulkBlast Environment Variables Template
# Copy this file to .env at the project root and fill in your values.
# DO NOT COMMIT .env TO SOURCE CONTROL.
#
# Expo reads these via `app.config.js` (dotenv) into `expo.extra`. After changing .env, restart Metro:
#   npx expo start -c

# Server-side proxy base URL (recommended: Cloudflare Worker).
# The Expo app must call your proxy; the proxy injects real API keys server-side.
#
# Example:
# EXPO_PUBLIC_PROXY_BASE_URL=https://bulkblast-proxy.yourname.workers.dev
EXPO_PUBLIC_PROXY_BASE_URL=

# Optional: POST launch events to Bags partner analytics (endpoint may 404 until enabled server-side).
EXPO_PUBLIC_BAGS_TRACK_LAUNCHES=

# Optional: Other environment-specific configurations
# EXPO_PUBLIC_API_URL=https://api.example.com
