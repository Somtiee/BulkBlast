# BulkBlast Environment Variables Template
# Copy this file to .env and fill in your actual values.
# DO NOT COMMIT .env TO SOURCE CONTROL.

# Helius RPC API Key (Get from https://helius.dev/)
EXPO_PUBLIC_HELIUS_API_KEY=your_helius_api_key_here

# Jupiter Swap API Key (Get from https://portal.jup.ag/)
EXPO_PUBLIC_JUPITER_API_KEY=your_jupiter_api_key_here

# Optional: Other environment-specific configurations
# EXPO_PUBLIC_API_URL=https://api.example.com
