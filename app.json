{
  "expo": {
    "name": "BulkBlast",
    "slug": "BulkBlast",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo-dark.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo-dark.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bulkblast.app"
    },
    "android": {
      "package": "com.bulkblast.app",
      "adaptiveIcon": {
        "backgroundColor": "#0F172A",
        "foregroundImage": "./assets/logo-dark.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-asset",
      "expo-font",
      "expo-sharing"
    ],
    "extra": {
      "eas": {
        "projectId": "af907db8-557e-4fcd-bb87-8f56f3d205cd"
      }
    }
  }
}
